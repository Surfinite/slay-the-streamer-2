# Decompiled output - regenerable from sts2.dll, large, and not "ours" to commit
decompiled/

# Reference repos - not ours, cloned fresh per workspace (see references/README.md)
references/

# Build artefacts
bin/
obj/
dist/
*.user
*.suo
# Auto-generated by `dotnet build` when no sln exists; we rely on per-csproj builds
*.sln
# dotnet incremental-build language-service cache
*.csproj.lscache

# Godot
.godot/
.import/

# IDE
.vs/
.idea/
.vscode/
*.code-workspace

# OS
Thumbs.db
.DS_Store

# Claude Code per-user state (commands/skills/shared settings DO get committed)
.claude/settings.local.json
# Claude Code worktrees: local isolated workspaces for feature branches,
# managed by the EnterWorktree/ExitWorktree harness tools.
.claude/worktrees/

# sts2.dll and 0Harmony.dll are copied per-build from the game install;
# they're MegaCrit / HarmonyLib binaries, not ours to redistribute.
src/sts2.dll
src/0Harmony.dll
# sts2.xml (MegaCrit's XML docs, shipped beside sts2.dll since game v0.107.1) is
# copied per-build for IDE IntelliSense — reference-only, not ours to redistribute.
src/sts2.xml

# External-review workflow inputs and raw reviewer outputs.
# Kept local-only: CONTEXT docs are throwaway inputs and raw _REVIEWS folders
# can contain reviewer commentary we don't want on a public repo.
# The synthesized META-REVIEW-*.md files ARE committed — that's the load-bearing artifact.
**/*-CONTEXT.md
**/*_REVIEWS/

# Steam Workshop workspace: content/ is synced from dist/ by workshop/upload.ps1
workshop/content/
